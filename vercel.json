{
  "buildCommand": "react-scripts build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/backup",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/ping-supabase",
      "schedule": "0 10 * * 1,3,5"
    },
    {
      "path": "/api/alertes",
      "schedule": "0 */6 * * *"
    }
  ],
  "env": {
    "CI": "false",
    "DISABLE_ESLINT_PLUGIN": "true",
    "GENERATE_SOURCEMAP": "false"
  },
  "framework": "create-react-app"
}
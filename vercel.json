{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/backup",
      "schedule": "0 23 * * *"
    }
  ],
  "buildCommand": "DISABLE_ESLINT_PLUGIN=true react-scripts build",
  "framework": "create-react-app"
}